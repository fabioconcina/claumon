# Supply-chain hardening for the extension's npm subtree.
# Most npm poisoning payloads execute via lifecycle (postinstall) scripts;
# refuse to run them. Safe here because the toolchain (typescript) has no
# binary postinstall step. If a dep ever needs one, run it explicitly.
ignore-scripts=true

# Never silently widen a version range; new installs pin the exact version.
save-exact=true

# Reproducible installs: error out instead of mutating the lockfile.
# (Use `npm ci`, not `npm install`, for clean installs.)
package-lock=true
